<IfModule mod_headers.c>
    SetEnvIf Origin "https://roshfinejewellery.com" ALLOWED_ORIGIN=$0
    SetEnvIf Origin "http://localhost:5173" ALLOWED_ORIGIN=$0

    Header always set Access-Control-Allow-Origin "%{ALLOWED_ORIGIN}e" env=ALLOWED_ORIGIN
    Header always set Access-Control-Allow-Credentials "true" env=ALLOWED_ORIGIN
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Authorization, Cache-Control, Expires, Pragma"
    Header always set Access-Control-Max-Age "86400"

    # Handle OPTIONS directly in LiteSpeed without waiting for Node.js
    RewriteEngine On
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ $1 [R=204,L]
</IfModule>
